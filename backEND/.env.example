# Backend Environment Variables
# Copy this file to .env and fill in actual values

# JWT Secret Key (make this unique and strong in production)
JWT_SECRET=your_jwt_secret_key_here

# MongoDB Connection String
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Node Environment (development, production, etc.)
NODE_ENV=development

# Optional: Frontend URL for CORS (set when deploying to production)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Firebase Admin SDK Service Account Key Path
# For Render: Add serviceAccountKey.json content as an env variable or use the file directly
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
